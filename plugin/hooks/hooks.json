{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/before-shell-execution.mjs\"",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/session-state-inject.mjs\"",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/memory-index-inject.mjs\"",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-session-init.mjs\"",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-pre-tool.mjs\"",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-post-tool.mjs\"",
        "timeout": 5
      }
    ],
    "beforeReadFile": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-before-read.mjs\"",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-after-file-edit.mjs\"",
        "timeout": 5
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-subagent-stop.mjs\"",
        "timeout": 5
      }
    ],
    "preCompact": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/pre-compact-notice.mjs\"",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/memory-extract-nudge.mjs\"",
        "timeout": 5,
        "loop_limit": 1
      },
      {
        "type": "command",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/dispatch-gate-stop.mjs\"",
        "timeout": 5,
        "loop_limit": 3
      }
    ]
  }
}
