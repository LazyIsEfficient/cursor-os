# Required for LLM stages (editorial-brain, content-transform without --template-only)
ANTHROPIC_API_KEY=

# Optional — shared data directory (default: ./data/)
# CONTENT_OPS_DATA_DIR=

# Optional — editorial-brain model override
# EDITORIAL_BRAIN_MODEL=claude-sonnet-4-20250514

# Optional — path to sibling content-ops skill (default: ../content-ops)
# CONTENT_OPS_SKILL_DIR=

# Optional — content-transform voice / style paths
# VOICE_CONFIG_FILE=
# STYLE_GUIDE_FILE=

# Optional — quote-mining feeds and notes
# QUOTE_MINING_FEEDS_FILE=
# QUOTE_MINING_FEEDS=
# QUOTE_MINING_NOTES_DIR=
# QUOTE_MINING_SPEAKER=
