{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-harness.local/schemas/benchmark-manifest.schema.json",
  "title": "Cursor Harness Benchmark Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "benchmarkId",
    "profile",
    "seed",
    "repetitions",
    "fixtures",
    "outputDirectory"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "benchmarkId": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "smoke-24",
        "release-72",
        "custom"
      ]
    },
    "seed": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "repetitions": {
      "type": "integer",
      "minimum": 1
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "outputDirectory": {
      "$ref": "#/$defs/relativePath"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "const": "smoke-24"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "repetitions": {
            "const": 1
          },
          "fixtures": {
            "minItems": 12,
            "maxItems": 12
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "const": "release-72"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "repetitions": {
            "const": 3
          },
          "fixtures": {
            "minItems": 12,
            "maxItems": 12
          }
        }
      }
    }
  ],
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+$"
    }
  }
}
