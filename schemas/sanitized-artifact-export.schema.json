{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-harness.local/schemas/sanitized-artifact-export.schema.json",
  "title": "Cursor Harness Sanitized Artifact Export",
  "description": "Hash manifest for an allowlisted benchmark evidence export that excludes raw workspaces and Cursor configuration homes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceRunId",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "sourceRunId": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file"
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?:plugin-lifecycle\\.json|results\\.ndjson|report\\.(?:json|md)|trials/[^/]+/artifacts/(?:stdout\\.log|stderr\\.log|stream\\.ndjson|telemetry\\.ndjson|evaluator-[a-z0-9-]+\\.(?:stdout|stderr)\\.log))$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
